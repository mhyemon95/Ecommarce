PORT=5000
MONGO_URI=mongodb://localhost:27017/auraglow
JWT_SECRET=superglowsecretkey123!

# ---------------------------------------------------
# Cloudinary Image Upload (Phase 5)
# Set these values from your Cloudinary dashboard to
# enable cloud storage with WebP auto-optimization.
# Leave blank to fall back to local disk storage.
# ---------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------------------------------------------------
# CORS Origin
# Set to your frontend's URL (e.g. http://localhost:3000)
# ---------------------------------------------------
CLIENT_ORIGIN=http://localhost:3000
